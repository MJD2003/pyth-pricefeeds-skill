# ═══════════════════════════════════════════════════════════
# Pyth Price Feeds — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Network ──────────────────────────────────────────────
# RPC endpoint for your target chain
RPC_URL=https://sepolia.optimism.io

# ─── Wallet ───────────────────────────────────────────────
# Private key for deploying and interacting (no 0x prefix needed for some tools)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── Pyth Contract ───────────────────────────────────────
# Find your chain's address at: https://docs.pyth.network/price-feeds/contract-addresses
#
# Common EVM mainnet addresses:
#   Ethereum:    0x4305FB66699C3B2702D4d05CF36551390A4c69C6
#   Arbitrum:    0xff1a0f4744e8582DF1aE09D5611b887B6a12925C
#   Optimism:    0xff1a0f4744e8582DF1aE09D5611b887B6a12925C
#   Base:        0x8250f4aF4B972684F7b336503E2D6dFeDeB1487a
#   Polygon:     0xff1a0f4744e8582DF1aE09D5611b887B6a12925C
#   Avalanche:   0x4305FB66699C3B2702D4d05CF36551390A4c69C6
#   BNB Chain:   0x4D7E825f80bDf85e913E0DD2A2D54927e9dE1594
#
# Common EVM testnet addresses:
#   Sepolia:         0xDd24F84d36BF92C65F92307595335bdFab5Bbd21
#   Arbitrum Sepolia: 0x4374e5a8b9C22271E9EB878A2AA31DE97DF15DAF
#   Base Sepolia:    0xA2aa501b19aff244D90cc15a4Cf739D2725B5729
#
PYTH_ADDRESS=0xff1a0f4744e8582DF1aE09D5611b887B6a12925C

# ─── Hermes (Off-Chain Price Service) ────────────────────
# Default public instance (rate-limited, suitable for development)
HERMES_URL=https://hermes.pyth.network

# ─── Your Deployed Consumer Contract ─────────────────────
# Set this after deploying your consumer contract
CONSUMER_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_HERE

# ─── Price Feed IDs ──────────────────────────────────────
# Find feed IDs at: https://docs.pyth.network/price-feeds/price-feeds
#
# Common feed IDs:
#   BTC/USD:  0xe62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43
#   ETH/USD:  0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace
#   SOL/USD:  0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d
#   USDC/USD: 0xeaa020c61cc479712813461ce153894a96a6c00b21ed0cfc2798d1f9a9e9c94a
#
PRICE_FEED_ID=0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace

# ─── Optional: Block Explorer API Key ────────────────────
# For contract verification
ETHERSCAN_API_KEY=

# ─── Optional: Oracle Swap Config ────────────────────────
# TOKEN_BASE=0x...
# TOKEN_QUOTE=0x...
# BASE_FEED_ID=0x...
# QUOTE_FEED_ID=0x...
